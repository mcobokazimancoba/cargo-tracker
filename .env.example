# =============================================================================
#  Cargo Tracker — example environment configuration
# =============================================================================
#
#  HOW TO USE
#  ----------
#  1. Copy this file to `.env` (which is gitignored).
#  2. Fill in real values for your environment.
#  3. Java does NOT auto-load `.env`. Pick one of these to apply the values:
#       a) Source the file before starting GlassFish:
#            set -a && source .env && set +a && asadmin start-domain
#       b) Or set each variable as a JVM option in GlassFish admin console
#          (Configurations → server-config → JVM Settings → JVM Options)
#          using the dotted form, e.g.  -Djwt.secret=<value>
#       c) Or export them in your shell profile (.bashrc / .zshrc / etc.)
#
#  Resolution order in the code:  -D system property → environment variable
#  → built-in default. Both shapes work; the dotted JVM-option form is what
#  GlassFish prefers for production.
#
#  WHAT'S NOT IN THIS FILE
#  -----------------------
#  Database credentials. Per Jakarta EE convention, the PostgreSQL connection
#  pool is configured INSIDE GlassFish (admin console → Resources → JDBC →
#  Connection Pools), and the app looks it up via JNDI as `jdbc/cargoTrackerDS`
#  (see `persistence.xml`). Putting DB creds in env vars on a Java EE app
#  bypasses the container's pooling and TLS handling — don't.

# =============================================================================
#  JWT signing
# =============================================================================
#
#  HS256 signing key for issued JWTs. Must be at least 32 bytes (256 bits).
#  If unset, AuthService generates a random per-JVM key at startup and logs
#  a stern WARNING. Tokens then get invalidated on every GlassFish restart —
#  acceptable in dev, never acceptable in production.
#
#  Generate a strong value with:
#      openssl rand -base64 48
JWT_SECRET=replace-me-with-at-least-32-random-bytes-from-openssl-rand

# =============================================================================
#  SMTP (used by password-reset and booking-confirmation emails)
# =============================================================================
#
#  Mailtrap is recommended for local dev — get free SMTP credentials at
#  https://mailtrap.io and emails are caught without hitting real inboxes.
MAIL_SMTP_HOST=smtp.mailtrap.io
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=noreply@cargotracker.example.com
MAIL_FROM_NAME=Cargo Tracker

# =============================================================================
#  Application base URL
# =============================================================================
#
#  Used to build absolute links in transactional emails (reset password,
#  booking confirmation). MUST match the public URL clients use to reach
#  the app — otherwise email links 404.
#
#  The context root `/Cargo_Tracker_System` comes from
#  `src/main/webapp/WEB-INF/glassfish-web.xml`. If you change it there,
#  update this value to match.
APP_BASE_URL=http://localhost:8080/Cargo_Tracker_System

# =============================================================================
#  Per-IP rate limit (RateLimitFilter)
# =============================================================================
#
#  Blanket rate limit on every non-OPTIONS request, sliding window.
RATELIMIT_REQUESTS=100
RATELIMIT_WINDOW_SECONDS=60

# =============================================================================
#  Brute-force protection on /api/auth/login (LoginThrottleService)
# =============================================================================
#
#  Stricter, scoped to login attempts only. Per-(IP, username) sliding
#  window — once tripped, the bucket replies 429 until old failures age
#  out. A successful login clears the bucket.
LOGIN_THROTTLE_MAX_FAILURES=5
LOGIN_THROTTLE_WINDOW_SECONDS=900
