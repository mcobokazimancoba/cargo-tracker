<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence">
    <persistence-unit name="cargoTrackerPU" transaction-type="JTA">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
        <jta-data-source>jdbc/cargoTrackerDS</jta-data-source>

        <class>com.cargotracker.entity.Cargo</class>
        <class>com.cargotracker.entity.Location</class>
        <class>com.cargotracker.entity.TrackingEvent</class>
        <class>com.cargotracker.entity.AppUser</class>
        <class>com.cargotracker.entity.PasswordResetToken</class>
        <class>com.cargotracker.entity.EmailVerificationToken</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <!-- Tables already exist, skip recreation -->
            <property name="jakarta.persistence.schema-generation.database.action"
                      value="none"/>

            <!-- Logging for debugging -->
            <property name="eclipselink.logging.level.sql" value="FINE"/>
            <property name="eclipselink.logging.parameters" value="true"/>
            <property name="eclipselink.target-database" value="PostgreSQL"/>
        </properties>
    </persistence-unit>
</persistence>