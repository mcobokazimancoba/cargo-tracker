<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="https://jakarta.ee/xml/ns/jakartaee"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                           https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd"
       version="4.0"
       bean-discovery-mode="annotated">

    <!--
        bean-discovery-mode="annotated"
        ──────────────────────────────
        CDI will only manage classes that carry a CDI scope annotation
        (@ApplicationScoped, @RequestScoped, @SessionScoped, @Dependent, etc.)
        or are explicitly registered.

        This is the correct default for production applications.
        "all" mode discovers every class on the classpath — including
        third-party library classes you did not intend to be CDI beans —
        which causes ambiguous-dependency errors and slow startup.

        GlassFish 7 / CDI 4.0 requires beans.xml for WAR deployments
        to activate CDI injection throughout the application.
    -->

</beans>